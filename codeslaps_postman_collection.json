    {
      "name": "Negative Tests - Invalid Routes",
      "item": [
        {
          "name": "GET Non-existent Page (404 check)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/this-page-does-not-exist-xyz",
              "host": ["{{baseUrl}}"],
              "path": ["this-page-does-not-exist-xyz"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404 or redirect handled gracefully', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([404, 200]);",
                  "});",
                  "pm.test('Response time is under 3000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
