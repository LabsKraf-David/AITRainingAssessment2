    {
      "name": "Security & Headers Tests",
      "item": [
        {
          "name": "Check Security Headers on Homepage",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('X-Frame-Options header present', function () {",
                  "    pm.expect(pm.response.headers.has('X-Frame-Options') || pm.response.headers.has('Content-Security-Policy')).to.be.true;",
                  "});",
                  "pm.test('HTTPS used (no mixed content risk)', function () {",
                  "    pm.expect(pm.request.url.toString()).to.include('https://');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "HTTP to HTTPS Redirect Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://www.codeslaps.com/",
              "protocol": "http",
              "host": ["www", "codeslaps", "com"],
              "path": [""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP redirects to HTTPS (301 or 302)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 301, 302, 308]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
