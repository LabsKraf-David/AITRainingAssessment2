# Copy this file to .env and fill in values before running tests.
# .env is gitignored — never commit real credentials.

# ── API & UI target ───────────────────────────────────────────────────────────
BASE_URL=https://www.codeslaps.com
API_BASE_URL=https://www.codeslaps.com

# ── Browser options ───────────────────────────────────────────────────────────
# Set HEADLESS=false to watch the browser during local debugging
HEADLESS=true
# Add milliseconds between actions when debugging (e.g. 500)
SLOW_MO=0

# ── TLS ───────────────────────────────────────────────────────────────────────
# Set to 0 when testing against local dev server with self-signed cert
NODE_TLS_REJECT_UNAUTHORIZED=1
